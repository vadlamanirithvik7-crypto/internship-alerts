# --- Database ---------------------------------------------------------------
# Local dev default is SQLite; set this to your Supabase pooled connection string
# for production (Supabase dashboard > Project Settings > Database > Connection string > URI).
DATABASE_URL=sqlite:///internships.db

# --- Alerting ---------------------------------------------------------------
# Gmail App Password (NOT your normal password): myaccount.google.com/apppasswords
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=
GMAIL_APP_PASSWORD=

# ntfy.sh topic. Pick something long and unguessable - the topic name is the
# only secret protecting your alerts. Subscribe to it in the ntfy mobile app.
NTFY_TOPIC=

# --- Free job APIs ----------------------------------------------------------
# Adzuna: https://developer.adzuna.com/ (free tier, no card)
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# USAJOBS: https://developer.usajobs.gov/apirequest/ (free, email signup)
USAJOBS_API_KEY=
USAJOBS_EMAIL=

# Contact address sent to SEC EDGAR in the User-Agent header (they ask for one).
SEC_CONTACT_EMAIL=
